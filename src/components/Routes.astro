---
const routes = [
  {
    origin: 'Ciudad de México',
    destination: 'Veracruz, Ver.',
    note: 'Carretera 150D · Puerto y zona industrial',
    tags: ['Puerto', 'Industrial', 'Importación / Exportación'],
  },
  {
    origin: 'Ciudad de México',
    destination: 'Puebla · Tlaxcala',
    note: 'Corredor industrial del Bajío y altiplano central',
    tags: ['Industrial', 'Manufactura'],
  },
  {
    origin: 'Ciudad de México',
    destination: 'Oaxaca · Tabasco · Yucatán · Campeche · Q. Roo',
    note: 'Cobertura total del sureste mexicano',
    tags: ['Multiestado', 'Comercial', 'Agroindustrial'],
  },
  {
    origin: 'Ciudad de México',
    destination: 'Corredor Interoceánico (Tehuantepec)',
    note: 'CDMX → Oaxaca → Istmo · Ruta estratégica de comercio exterior',
    tags: ['Estratégico', 'Comercio exterior'],
    highlight: true,
  },
];
---

<section id="rutas" class="bg-navy bg-hex-lines py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="mb-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="text-blue-accent text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
          Rutas y cobertura
        </p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight" data-anim="fade-up" data-delay="80">
          Llegamos donde tu carga necesita ir
        </h2>
      </div>
      <p class="text-muted-dark text-sm max-w-xs shrink-0" data-anim="fade-up" data-delay="140">
        Rutas establecidas desde CDMX hacia los principales centros económicos del país.
      </p>
    </div>

    <!-- Route list -->
    <div class="space-y-3">
      {routes.map((r, i) => (
        <div
          class="group rounded-xl border px-6 py-5 flex flex-col sm:flex-row sm:items-center gap-4 transition-all duration-200 hover:border-blue-accent/50"
          style={r.highlight
            ? 'background:rgba(0,200,255,0.05);border-color:rgba(0,200,255,0.25);'
            : 'background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.08);'}
          data-anim="fade-up"
          data-delay={i * 100}
        >
          <!-- Origin → Destination -->
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <!-- Dot -->
            <span class="w-2 h-2 rounded-full shrink-0"
                  style={r.highlight ? 'background:#00c8ff;' : 'background:#1a5fb8;'}
                  aria-hidden="true"></span>
            <!-- Origin: full name on ≥sm, abbreviation on mobile -->
            <span class="text-sm font-medium text-white/70 shrink-0">
              <span class="hidden sm:inline">{r.origin}</span>
              <span class="sm:hidden">CDMX</span>
            </span>

            <!-- Arrow -->
            <svg class="w-4 h-4 shrink-0 text-blue-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/>
            </svg>

            <!-- Destination — no truncate, wraps naturally -->
            <span class="text-sm font-bold text-white leading-snug"
                  style={r.highlight ? 'color:#00c8ff;' : ''}>{r.destination}</span>
          </div>

          <!-- Note -->
          <p class="text-xs text-muted-dark hidden lg:block shrink-0 max-w-xs">{r.note}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5 shrink-0">
            {r.tags.map((tag) => (
              <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full"
                    style={r.highlight
                      ? 'color:#00c8ff;background:rgba(0,200,255,0.12);'
                      : 'color:#5c9fe0;background:rgba(92,159,224,0.12);'}>
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Footer note + CTA -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-5" data-anim="fade-up" data-delay="440">
      <p class="text-muted-dark text-sm text-center sm:text-left">
        ¿Tu destino no aparece? Cubrimos toda la República — consúltanos.
      </p>
      <a
        href="#cotizar"
        class="inline-flex items-center gap-2 border border-blue-accent/40 text-blue-accent text-sm font-semibold px-6 py-3 rounded-full hover:bg-blue-accent/10 transition-colors shrink-0"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
        </svg>
        Consultar disponibilidad
      </a>
    </div>

  </div>
</section>
