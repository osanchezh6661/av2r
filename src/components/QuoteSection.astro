---
// TODO: Reemplaza TALLY_FORM_ID con el ID real de tu formulario Tally
// Ejemplo: si tu URL es https://tally.so/r/abc123, el ID es "abc123"
const TALLY_FORM_ID = 'PENDING';
// Reemplaza con foto real de la flota cuando esté disponible
const BG_IMG = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1920&q=70';
---
<section
  id="cotizar"
  class="relative parallax-section overflow-hidden"
  style="min-height: 520px;"
  data-parallax-section
>
  <!-- Foto de camión de fondo con parallax -->
  <img
    src={BG_IMG}
    alt=""
    aria-hidden="true"
    class="parallax-img"
    data-parallax="0.3"
    width="1920"
    height="900"
    loading="lazy"
  />

  <!-- Overlay navy intenso -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, rgba(11,29,58,0.96) 0%, rgba(18,45,90,0.94) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Orb decorativo -->
  <div
    class="pointer-events-none absolute left-0 bottom-0 w-72 h-72 rounded-full opacity-15"
    style="background: radial-gradient(circle, #00c8ff 0%, transparent 70%); transform: translate(-30%, 30%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-24">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-blue-accent text-xs font-semibold tracking-widest uppercase mb-4"
         data-anim="fade-up">
        Cotización sin costo
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight mb-4"
          data-anim="fade-up" data-delay="80">
        Obtén tu cotización ahora
      </h2>
      <p class="text-[#7a9bbf] text-base max-w-xl mx-auto leading-relaxed"
         data-anim="fade-up" data-delay="160">
        Cuéntanos qué necesitas mover y te respondemos a la brevedad.
        Sin compromiso, sin costos ocultos.
      </p>
    </div>

    <!-- Contenedor del formulario Tally -->
    <div class="max-w-2xl mx-auto" data-anim="scale-up" data-delay="250">
      <div class="bg-white rounded-2xl overflow-hidden shadow-2xl">

        {TALLY_FORM_ID !== 'PENDING' ? (
          <>
            {/* Embed de Tally — activo cuando tienes el ID */}
            <iframe
              data-tally-src={`https://tally.so/embed/${TALLY_FORM_ID}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`}
              loading="lazy"
              width="100%"
              height="300"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              title="Formulario de cotización AV2R La Mundial"
            ></iframe>
            <!-- Pega aquí el snippet oficial de Tally cuando tengas el ID -->
            <!-- <script src="https://tally.so/widgets/embed.js"></script> -->
          </>
        ) : (
          /* Placeholder hasta que tengas el ID de Tally */
          <div class="p-10 text-center">
            <div class="w-16 h-16 rounded-full bg-blue/10 flex items-center justify-center mx-auto mb-5">
              <svg class="w-8 h-8 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
              </svg>
            </div>
            <h3 class="text-navy text-lg font-bold mb-2">Formulario de cotización</h3>
            <p class="text-muted text-sm mb-6 max-w-sm mx-auto">
              El formulario estará disponible próximamente.<br />
              Mientras tanto, contáctanos directamente:
            </p>
            <a
              href="tel:5510530425"
              class="inline-flex items-center gap-2 bg-blue text-white font-semibold text-sm px-7 py-3.5 rounded-md hover:bg-navy transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Llamar: 55 1053 0425
            </a>
          </div>
        )}

      </div>
    </div>

  </div>
</section>
