---
import { FORMSPREE_ENDPOINT, PHONE, PHONE_DISPLAY, WA_CONTACT_URL } from '../config';
---

<section id="cotizar" class="bg-surface bg-dots py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: headline + trust signals -->
      <div>
        <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
          Cotización sin costo
        </p>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight mb-4" data-anim="fade-up" data-delay="80">
          Obtén tu cotización en minutos
        </h2>
        <p class="text-muted text-base leading-relaxed mb-6" data-anim="fade-up" data-delay="140">
          Cuéntanos qué necesitas mover. Sin compromiso, sin costos ocultos.
        </p>

        <!-- Response time badge -->
        <div class="inline-flex items-center gap-3 rounded-xl px-5 py-3 mb-8 border" data-anim="fade-up" data-delay="180"
             style="background:rgba(0,200,255,0.06);border-color:rgba(0,200,255,0.25);">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color:#00c8ff;" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <p class="text-sm font-bold" style="color:#00c8ff;">Respuesta en menos de 30 minutos</p>
            <p class="text-xs text-muted">Lunes a domingo, todo el día</p>
          </div>
        </div>

        <!-- Trust signals -->
        <div class="space-y-4" data-anim="fade-up" data-delay="200">
          {[
            { label: 'Respuesta garantizada en menos de 30 min', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>` },
            { label: 'Precio final, sin cargos sorpresa', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>` },
            { label: 'Operadores certificados con licencia federal', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>` },
            { label: 'Seguro de carga activo en todos los servicios', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>` },
          ].map((item) => (
            <div class="flex items-center gap-3">
              <span class="text-blue shrink-0"><Fragment set:html={item.icon} /></span>
              <span class="text-sm text-navy font-medium">{item.label}</span>
            </div>
          ))}
        </div>

        <!-- Direct contact -->
        <div class="mt-10 pt-8 border-t border-border" data-anim="fade-up" data-delay="300">
          <p class="text-xs text-muted mb-3">¿Prefieres hablar directamente?</p>
          <div class="flex flex-wrap gap-3">
            <a href={`tel:${PHONE}`}
               class="inline-flex items-center gap-2 border border-border text-navy text-sm font-semibold px-5 py-2.5 rounded-full hover:border-blue hover:text-blue transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
              </svg>
              {PHONE_DISPLAY}
            </a>
            <a href={WA_CONTACT_URL}
               target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-[#25D366] text-white text-sm font-semibold px-5 py-2.5 rounded-full hover:brightness-110 transition-all">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div data-anim="slide-right" data-delay="100">
        <div class="bg-white rounded-2xl border border-border shadow-sm p-7 lg:p-8">
          <h3 class="text-navy text-lg font-bold mb-6">Solicitar cotización</h3>

          <form
            action={FORMSPREE_ENDPOINT}
            method="POST"
            id="quote-form"
            class="space-y-4"
          >
            <!-- Hidden fields -->
            <input type="hidden" name="_subject" value="Nueva cotización — AV2R La Mundial" />
            <input type="hidden" name="_next" value="/#cotizar" />
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

            <!-- Row 1 -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="f-nombre" class="block text-xs font-semibold text-navy mb-1.5">Nombre <span class="text-red-500">*</span></label>
                <input id="f-nombre" name="nombre" type="text" required
                       placeholder="Tu nombre"
                       data-validate="text"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten letras y espacios.</p>
              </div>
              <div>
                <label for="f-empresa" class="block text-xs font-semibold text-navy mb-1.5">Empresa</label>
                <input id="f-empresa" name="empresa" type="text"
                       placeholder="Nombre de tu empresa"
                       data-validate="text"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten letras y espacios.</p>
              </div>
            </div>

            <!-- Row 2 -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="f-tel" class="block text-xs font-semibold text-navy mb-1.5">Teléfono <span class="text-red-500">*</span></label>
                <input id="f-tel" name="telefono" type="tel" required
                       placeholder="55 xxxx xxxx"
                       inputmode="numeric"
                       data-validate="phone"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten números.</p>
              </div>
              <div>
                <label for="f-email" class="block text-xs font-semibold text-navy mb-1.5">Correo electrónico <span class="text-red-500">*</span></label>
                <input id="f-email" name="email" type="email" required
                       placeholder="tu@empresa.com"
                       data-validate="email"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Ingresa un correo electrónico válido.</p>
              </div>
            </div>

            <!-- Row 3 -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="f-origen" class="block text-xs font-semibold text-navy mb-1.5">Origen <span class="text-red-500">*</span></label>
                <input id="f-origen" name="origen" type="text" required
                       placeholder="Ciudad / dirección de recolección"
                       data-validate="text"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten letras y espacios.</p>
              </div>
              <div>
                <label for="f-destino" class="block text-xs font-semibold text-navy mb-1.5">Destino <span class="text-red-500">*</span></label>
                <input id="f-destino" name="destino" type="text" required
                       placeholder="Ciudad / dirección de entrega"
                       data-validate="text"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten letras y espacios.</p>
              </div>
            </div>

            <!-- Row 4 -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="f-carga" class="block text-xs font-semibold text-navy mb-1.5">Tipo de carga</label>
                <input id="f-carga" name="tipo_carga" type="text"
                       placeholder="Ej. materiales, maquinaria..."
                       data-validate="text"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten letras y espacios.</p>
              </div>
              <div>
                <label for="f-peso" class="block text-xs font-semibold text-navy mb-1.5">Peso aproximado (kg)</label>
                <input id="f-peso" name="peso" type="text"
                       placeholder="Ej. 3000"
                       inputmode="numeric"
                       data-validate="number"
                       class="field w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors" />
                <p class="field-error hidden text-[11px] text-red-500 mt-1">Solo se permiten números.</p>
              </div>
            </div>

            <!-- Fecha -->
            <div>
              <label for="f-fecha" class="block text-xs font-semibold text-navy mb-1.5">Fecha requerida</label>
              <div class="relative">
                <input id="f-fecha" name="fecha" type="date"
                       class="w-full text-sm border border-border rounded-lg px-3.5 py-2.5 pr-10 text-navy focus:outline-none focus:border-blue transition-colors cursor-pointer"
                       style="-webkit-appearance:auto;" />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-muted">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z"/>
                  </svg>
                </span>
              </div>
            </div>

            <!-- Notas -->
            <div>
              <label for="f-notas" class="block text-xs font-semibold text-navy mb-1.5">Notas adicionales</label>
              <textarea id="f-notas" name="notas" rows="3"
                        placeholder="Cualquier detalle relevante sobre tu carga o servicio..."
                        class="w-full text-sm border border-border rounded-lg px-3.5 py-2.5 text-navy placeholder-muted/60 focus:outline-none focus:border-blue transition-colors resize-none"></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-blue text-white text-sm font-bold py-3.5 rounded-full hover:bg-navy transition-colors"
              style="box-shadow:0 2px 16px rgba(26,95,184,0.30);"
            >
              Enviar solicitud de cotización
            </button>

            <p class="text-center text-[11px] text-muted">* Campos requeridos · Respuesta en menos de 30 minutos</p>
          </form>

          <!-- Success message (shown via JS) -->
          <div id="form-success" class="hidden text-center py-8">
            <div class="w-14 h-14 rounded-full bg-green-50 border border-green-200 flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-navy font-bold text-lg mb-1">¡Solicitud enviada!</h3>
            <p class="text-muted text-sm">Te contactamos en menos de 30 minutos.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  /* ── Date picker ── */
  const fechaInput = document.getElementById('f-fecha');
  if (fechaInput) {
    fechaInput.min = new Date().toISOString().split('T')[0];
    fechaInput.addEventListener('click', () => {
      if (typeof fechaInput.showPicker === 'function') fechaInput.showPicker();
    });
  }

  /* ── Field validation ── */
  const TEXT_RE   = /^[A-Za-záéíóúÁÉÍÓÚüÜñÑ\s,.\-/]+$/;
  const NUMBER_RE = /^\d+$/;
  const PHONE_RE  = /^[\d\s\+\-\(\)]+$/;
  const EMAIL_RE  = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function isValid(type, val) {
    if (val === '') return true; // empty = let `required` handle it
    if (type === 'text')   return TEXT_RE.test(val);
    if (type === 'number') return NUMBER_RE.test(val);
    if (type === 'phone')  return PHONE_RE.test(val);
    if (type === 'email')  return EMAIL_RE.test(val);
    return true;
  }

  function setError(input, hasError) {
    const err = input.parentElement.querySelector('.field-error');
    if (hasError) {
      input.style.borderColor = '#ef4444';
      err && err.classList.remove('hidden');
    } else {
      input.style.borderColor = '';
      err && err.classList.add('hidden');
    }
  }

  /* Block invalid chars on keydown for number/phone fields */
  document.querySelectorAll('[data-validate="number"], [data-validate="phone"]').forEach(input => {
    input.addEventListener('keydown', (e) => {
      const allowed = ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Enter','Home','End'];
      if (allowed.includes(e.key)) return;
      const isDigit = /^\d$/.test(e.key);
      const isFormat = input.dataset.validate === 'phone' && /^[\s\+\-\(\)]$/.test(e.key);
      if (!isDigit && !isFormat) e.preventDefault();
    });
  });

  /* Block non-letter chars on input for text fields (strips on paste too) */
  document.querySelectorAll('[data-validate="text"]').forEach(input => {
    input.addEventListener('input', () => {
      const cleaned = input.value.replace(/[^A-Za-záéíóúÁÉÍÓÚüÜñÑ\s,.\-/]/g, '');
      if (cleaned !== input.value) input.value = cleaned;
      if (input.value) setError(input, false);
    });
    input.addEventListener('blur', () => {
      if (input.value) setError(input, !isValid('text', input.value));
    });
  });

  /* Validate phone/number on blur */
  document.querySelectorAll('[data-validate="phone"], [data-validate="number"]').forEach(input => {
    input.addEventListener('blur', () => {
      if (input.value) setError(input, !isValid(input.dataset.validate, input.value));
    });
    input.addEventListener('input', () => {
      if (input.value) setError(input, false);
    });
  });

  /* Validate email on blur */
  document.querySelectorAll('[data-validate="email"]').forEach(input => {
    input.addEventListener('blur', () => {
      if (input.value) setError(input, !isValid('email', input.value));
    });
    input.addEventListener('input', () => {
      if (input.value) setError(input, false);
    });
  });

  /* ── Form submit ── */
  const form = document.getElementById('quote-form');
  const success = document.getElementById('form-success');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      /* Validate all fields before sending */
      let hasErrors = false;
      form.querySelectorAll('.field[data-validate]').forEach(input => {
        const type = input.dataset.validate;
        if (input.value && !isValid(type, input.value)) {
          setError(input, true);
          hasErrors = true;
        }
        if (input.required && !input.value.trim()) {
          input.style.borderColor = '#ef4444';
          hasErrors = true;
        }
      });
      if (hasErrors) return;

      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Enviando...';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          btn.disabled = false;
          btn.textContent = 'Enviar solicitud de cotización';
          alert('Hubo un error. Inténtalo de nuevo o contáctanos por WhatsApp.');
        }
      } catch {
        btn.disabled = false;
        btn.textContent = 'Enviar solicitud de cotización';
        alert('Hubo un error de conexión. Inténtalo de nuevo.');
      }
    });
  }
</script>
