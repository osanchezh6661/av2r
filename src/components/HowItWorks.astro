---
const steps = [
  {
    title: 'Cotiza',
    desc: 'Llena el formulario, llámanos o escríbenos por WhatsApp. Te respondemos en menos de 30 minutos.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
  {
    title: 'Confirmamos',
    desc: 'Definimos ruta, precio final sin costos ocultos y fecha de servicio. Sin sorpresas.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Recolección',
    desc: 'Un operador certificado llega a tu dirección en la fecha acordada para cargar tu mercancía.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>`,
  },
  {
    title: 'Entrega con GPS',
    desc: 'Seguimiento en tiempo real durante todo el trayecto. Confirmación de entrega al llegar a destino.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
  },
];
---

<section id="como-funciona" class="bg-navy py-16 lg:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-blue-accent text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
        Proceso simple
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight" data-anim="fade-up" data-delay="80">
        ¿Cómo funciona?
      </h2>
      <p class="text-muted-dark text-sm mt-3 max-w-md mx-auto" data-anim="fade-up" data-delay="160">
        En cuatro pasos tu mercancía está en camino. Sin burocracia, sin sorpresas.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="relative grid md:grid-cols-4 gap-8">

      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-10 left-[12.5%] right-[12.5%] h-px"
           style="background:linear-gradient(90deg,transparent,rgba(92,159,224,0.35) 15%,rgba(92,159,224,0.35) 85%,transparent);"
           aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div class="relative flex flex-col items-center text-center" data-anim="fade-up" data-delay={i * 120}>

          <!-- Circle -->
          <div class="relative w-20 h-20 rounded-full flex items-center justify-center mb-6 z-10"
               style="background:linear-gradient(135deg,#1a5fb8 0%,#0b1d3a 100%);box-shadow:0 0 0 8px rgba(26,95,184,0.10);">
            <span class="text-blue-accent">
              <Fragment set:html={step.icon} />
            </span>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-neon text-navy text-[10px] font-black flex items-center justify-center"
                  style="box-shadow:0 0 10px rgba(0,200,255,0.6);">
              {i + 1}
            </span>
          </div>

          <h3 class="text-white font-bold text-base mb-2">{step.title}</h3>
          <p class="text-muted-dark text-sm leading-relaxed max-w-[200px]">{step.desc}</p>
        </div>
      ))}
    </div>


  </div>
</section>
