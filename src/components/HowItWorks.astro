---
const steps = [
  {
    num: '01',
    title: 'Contáctanos',
    desc: 'Llámanos, escríbenos por WhatsApp o llena el formulario. Un asesor te responde en menos de 2 horas hábiles.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
    </svg>`,
  },
  {
    num: '02',
    title: 'Recibe tu cotización',
    desc: 'Diseñamos la ruta óptima para tu carga, te enviamos el precio final sin costos ocultos y confirmamos disponibilidad.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
    </svg>`,
  },
  {
    num: '03',
    title: 'Tu carga llega a tiempo',
    desc: 'Recolectamos, transportamos con rastreo GPS en tiempo real y entregamos en destino. Confirmación de entrega incluida.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`,
  },
];
---
<section id="como-funciona" class="bg-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3"
         data-anim="fade-up">
        Proceso simple
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight"
          data-anim="fade-up" data-delay="80">
        ¿Cómo funciona?
      </h2>
      <p class="text-muted text-sm mt-3 max-w-md mx-auto"
         data-anim="fade-up" data-delay="160">
        En tres pasos tu mercancía está en camino. Sin burocracia, sin sorpresas.
      </p>
    </div>

    <!-- Pasos -->
    <div class="relative grid md:grid-cols-3 gap-8">

      <!-- Línea conectora (desktop) -->
      <div class="hidden md:block absolute top-10 left-[16.66%] right-[16.66%] h-px"
           style="background: linear-gradient(90deg, transparent, #1a5fb8 20%, #1a5fb8 80%, transparent);"
           aria-hidden="true">
      </div>

      {steps.map((step, i) => (
        <div
          class="relative flex flex-col items-center text-center"
          data-anim="fade-up"
          data-delay={i * 140}
        >
          <!-- Círculo numerado -->
          <div
            class="relative w-20 h-20 rounded-full flex items-center justify-center mb-6 z-10"
            style="background: linear-gradient(135deg, #1a5fb8 0%, #0b1d3a 100%); box-shadow: 0 0 0 8px rgba(26,95,184,0.10);"
          >
            <span class="text-neon" style="filter: drop-shadow(0 0 6px rgba(0,200,255,0.7));">
              <Fragment set:html={step.icon} />
            </span>
            <!-- Número flotante -->
            <span
              class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-neon text-navy text-[10px] font-black flex items-center justify-center"
              style="box-shadow: 0 0 10px rgba(0,200,255,0.6);"
            >
              {i + 1}
            </span>
          </div>

          <h3 class="text-navy font-bold text-base mb-2">{step.title}</h3>
          <p class="text-muted text-sm leading-relaxed max-w-xs">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="mt-14 text-center" data-anim="fade-up" data-delay="460">
      <a
        href="#cotizar"
        class="inline-flex items-center gap-2 bg-blue text-white text-sm font-semibold px-8 py-3.5 rounded-md hover:bg-navy transition-colors"
      >
        Empezar ahora
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
