---
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3"
         data-anim="fade-up">
        Sectores
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight"
          data-anim="fade-up" data-delay="80">
        Industrias que atendemos
      </h2>
      <p class="text-muted text-sm mt-3 max-w-lg mx-auto"
         data-anim="fade-up" data-delay="160">
        Experiencia en múltiples sectores. Soluciones de transporte a la medida de cada industria.
      </p>
    </div>

    <!-- Grid 3×2 -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sectors.map((sector, i) => (
        <div
          class="group flex items-start gap-4 p-5 rounded-xl border border-border bg-surface hover:bg-white hover:border-blue/30 hover:shadow-sm transition-all duration-300"
          data-anim="fade-up"
          data-delay={i * 80}
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 text-blue group-hover:text-neon transition-colors"
            style="background: rgba(26,95,184,0.07);"
          >
            <Fragment set:html={sector.icon} />
          </div>
          <div>
            <h3 class="text-navy text-sm font-semibold mb-1.5">{sector.title}</h3>
            <p class="text-muted text-xs leading-relaxed">{sector.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
