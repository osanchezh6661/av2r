---
const stats = [
  { value: '5',    label: 'Unidades activas',        sub: 'Flota propia, sin intermediarios' },
  { value: '5',    label: 'Operadores certificados', sub: 'Licencia federal vigente' },
  { value: '4',    label: 'Sectores atendidos',      sub: 'Industrial, Comercial, Construcción, Agro' },
  { value: '24/7', label: 'Operación continua',      sub: 'Los 365 días del año' },
];

const values = [
  { label: 'Responsabilidad', desc: 'Cumplimos cada compromiso adquirido.' },
  { label: 'Seguridad',       desc: 'Priorizamos la integridad de la carga y las personas.' },
  { label: 'Puntualidad',     desc: 'Entregas en tiempo como estándar, no como excepción.' },
  { label: 'Confianza',       desc: 'Relaciones a largo plazo basadas en resultados reales.' },
  { label: 'Mejora continua', desc: 'Evolución constante en procesos y operación.' },
];

const certs = [
  { label: 'Reg. SICT', sub: 'Secretaría de Infraestructura, Comunicaciones y Transportes' },
  { label: 'NOM-068',   sub: 'Condiciones físico-mecánicas de vehículos' },
  { label: 'NOM-012',   sub: 'Pesos y dimensiones en vías generales' },
  { label: 'Seguro de carga', sub: 'Activo en todos los servicios' },
  { label: 'Licencia federal', sub: 'Operadores con tipo acorde a la unidad' },
];
---

<section id="nosotros-info" class="bg-surface bg-dots py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="mb-12">
      <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
        Quiénes somos
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight" data-anim="fade-up" data-delay="80">
        Empresa mexicana comprometida<br class="hidden lg:block" /> con cada traslado
      </h2>
    </div>

    <!-- Two-column layout -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: text -->
      <div data-anim="fade-up" data-delay="100">
        <p class="text-muted text-base leading-relaxed mb-8">
          AV2R La Mundial es una empresa de transporte terrestre de carga con base en Ciudad de México.
          Operamos rutas hacia Veracruz, el sureste mexicano y el Corredor Interoceánico, atendiendo
          a empresas de los sectores industrial, comercial, construcción y agroindustrial.
        </p>

        <!-- Misión -->
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-1 h-5 rounded-full bg-blue shrink-0" aria-hidden="true"></div>
            <h3 class="text-navy text-sm font-bold uppercase tracking-wide">Misión</h3>
          </div>
          <p class="text-muted text-sm leading-relaxed pl-3">
            Brindar soluciones de transporte de carga confiables, seguras y eficientes, generando
            valor para nuestros clientes mediante un servicio puntual, profesional y adaptado
            a sus necesidades logísticas.
          </p>
        </div>

        <!-- Visión -->
        <div class="mb-8">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-1 h-5 rounded-full bg-blue shrink-0" aria-hidden="true"></div>
            <h3 class="text-navy text-sm font-bold uppercase tracking-wide">Visión</h3>
          </div>
          <p class="text-muted text-sm leading-relaxed pl-3">
            Ser una empresa de transporte reconocida a nivel nacional por su calidad operativa,
            confiabilidad y estándares de servicio, consolidándonos como aliado estratégico en
            la cadena logística de nuestros clientes.
          </p>
        </div>

        <!-- Valores -->
        <div class="space-y-3">
          <p class="text-[10px] font-bold text-muted uppercase tracking-widest mb-4">Valores</p>
          {values.map((v) => (
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-blue mt-0.5 shrink-0" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="9" stroke="#1a5fb8" stroke-width="1.5"/>
                <path d="M6.5 10.5l2.5 2.5 4.5-5" stroke="#5c9fe0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <span class="text-xs font-semibold text-navy">{v.label}</span>
                <span class="text-xs text-muted"> — {v.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: dark card with stats -->
      <div data-anim="slide-right" data-delay="120">
        <div class="rounded-2xl p-7 space-y-6"
             style="background:linear-gradient(135deg,#0b1d3a 0%,#122d5a 100%);border:1px solid rgba(92,159,224,0.15);">

          <div class="border-b border-white/10 pb-5">
            <p class="text-blue-accent text-[10px] font-semibold tracking-widest uppercase mb-1">AV2R La Mundial</p>
            <h3 class="text-white text-lg font-bold">La empresa en números</h3>
          </div>

          <div class="grid grid-cols-2 gap-5">
            {stats.map((s) => (
              <div>
                <p class="text-white text-3xl font-black tracking-tight mb-0.5"
                   style="text-shadow:0 0 20px rgba(92,159,224,0.40);">{s.value}</p>
                <p class="text-blue-accent text-xs font-semibold mb-0.5">{s.label}</p>
                <p class="text-muted-dark text-[10px] leading-snug">{s.sub}</p>
              </div>
            ))}
          </div>

        </div>
      </div>

    </div>

    <!-- Certifications strip -->
    <div class="mt-14 pt-10 border-t border-border" data-anim="fade-up" data-delay="300">
      <p class="text-[10px] font-bold text-muted uppercase tracking-widest mb-6 text-center">
        Cumplimiento normativo
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {certs.map((c) => (
          <div class="bg-white border border-border rounded-xl p-4 text-center">
            <p class="text-navy text-xs font-bold mb-1">{c.label}</p>
            <p class="text-muted text-[10px] leading-snug">{c.sub}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
