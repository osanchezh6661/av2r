---
const items = [
  'Empresa mexicana',
  'Seguro de carga incluido',
  'Operación 24/7',
  'Atención personalizada',
];
---
<div class="bg-white border-b border-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4">
    <ul class="flex flex-wrap items-center gap-x-6 gap-y-2">
      {items.map((item, i) => (
        <li
          class="flex items-center gap-2"
          data-anim="fade-up"
          data-delay={i * 80}
        >
          <span class="w-2 h-2 rounded-full bg-blue shrink-0" aria-hidden="true"></span>
          <span class="text-muted text-xs font-medium">{item}</span>
          {i < items.length - 1 && (
            <span class="hidden sm:block w-px h-4 bg-border ml-4" aria-hidden="true"></span>
          )}
        </li>
      ))}
    </ul>
  </div>
</div>
