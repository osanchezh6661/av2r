---
// MOCK — Reemplazar con reseñas reales extraídas de Google Maps, Facebook e Instagram
// cuando el cliente proporcione acceso a las plataformas.
const reviews = [
  {
    platform: 'google',
    author: 'Juan Carlos Martínez',
    company: 'Ganaderos del Sur S.A.',
    location: 'Veracruz, Ver.',
    rating: 5,
    text: 'Llevamos más de 2 años enviando ganado con AV2R y nunca hemos tenido un problema. Las jaulas llegan limpias, los operadores son muy atentos y el ganado llega en perfectas condiciones. Los recomiendo ampliamente.',
    avatar: 'JM',
    date: 'hace 1 mes',
  },
  {
    platform: 'facebook',
    author: 'Ing. Rebeca Salinas',
    company: 'Distribuidora Morelos',
    location: 'Ciudad de México',
    rating: 5,
    text: 'Cotizamos con varias empresas y AV2R nos dio el mejor precio y la respuesta más rápida. En menos de una hora ya teníamos la cotización. El flete llegó a tiempo y sin ningún daño. Excelente servicio.',
    avatar: 'RS',
    date: 'hace 3 semanas',
  },
  {
    platform: 'google',
    author: 'Carlos Ibáñez',
    company: 'Ibáñez Constructora',
    location: 'Oaxaca, Oax.',
    rating: 5,
    text: 'Transportamos maquinaria pesada en plataforma al Corredor Interoceánico. El equipo llegó sin un rasguño y antes de lo estimado. El rastreo GPS fue muy útil para coordinar la recepción. Muy profesionales.',
    avatar: 'CI',
    date: 'hace 2 meses',
  },
  {
    platform: 'instagram',
    author: '@grupologistico_mx',
    company: 'Grupo Logístico MX',
    location: 'Chiapas',
    rating: 5,
    text: 'Increíble servicio. Movemos carga al sureste regularmente con AV2R y siempre cumplen. Precio justo, puntualidad y excelente comunicación durante todo el trayecto.',
    avatar: 'GL',
    date: 'hace 5 días',
  },
  {
    platform: 'facebook',
    author: 'María Fernanda Torres',
    company: 'Comercializadora Torres',
    location: 'Tabasco',
    rating: 5,
    text: 'Tuvimos una urgencia y AV2R nos ayudó en menos de 24 horas. No esperábamos una respuesta tan rápida. La mercancía llegó perfecta. Definitivamente seguiremos trabajando con ellos.',
    avatar: 'MT',
    date: 'hace 1 semana',
  },
  {
    platform: 'google',
    author: 'Roberto Vega',
    company: 'Agroindustrias Vega',
    location: 'Yucatán',
    rating: 5,
    text: 'Buen servicio, buena comunicación y precio competitivo. Ya van varios fletes y sin problemas. Lo que más valoro es que siempre hay alguien disponible para atender cualquier duda.',
    avatar: 'RV',
    date: 'hace 3 meses',
  },
];

const platformConfig = {
  google: {
    label: 'Google Maps',
    color: '#4285F4',
    icon: `<svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
    </svg>`,
  },
  facebook: {
    label: 'Facebook',
    color: '#1877F2',
    icon: `<svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>`,
  },
  instagram: {
    label: 'Instagram',
    color: '#E1306C',
    icon: `<svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
    </svg>`,
  },
};

const overallRating = 4.9;
const totalReviews = 127; // TODO: actualizar con conteo real
---

<section id="reseñas" class="bg-surface py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
      <div>
        <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3"
           data-anim="fade-up">
          Reseñas verificadas
        </p>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight"
            data-anim="fade-up" data-delay="80">
          Lo que dicen nuestros clientes
        </h2>
      </div>

      <!-- Rating global -->
      <div class="flex items-center gap-4 shrink-0" data-anim="fade-up" data-delay="120">
        <div class="text-center">
          <p class="text-5xl font-black text-navy leading-none">{overallRating}</p>
          <div class="flex gap-0.5 mt-1 justify-center">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-muted text-xs mt-1">{totalReviews} reseñas</p>
        </div>

        <!-- Plataformas -->
        <div class="flex flex-col gap-1.5">
          {Object.entries(platformConfig).map(([key, cfg]) => (
            <div class="flex items-center gap-1.5">
              <span style={`color: ${cfg.color}`}>
                <Fragment set:html={cfg.icon} />
              </span>
              <span class="text-muted text-xs">{cfg.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Grid de reseñas -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {reviews.map((review, i) => {
        const cfg = platformConfig[review.platform];
        return (
          <article
            class="bg-white rounded-xl border border-border p-5 flex flex-col gap-4 neon-card"
            data-anim="fade-up"
            data-delay={i * 80}
          >
            <!-- Header: avatar + nombre + plataforma -->
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <!-- Avatar iniciales -->
                <div
                  class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0"
                  style={`background: linear-gradient(135deg, #0b1d3a, #1a5fb8);`}
                >
                  {review.avatar}
                </div>
                <div>
                  <p class="text-navy text-sm font-semibold leading-tight">{review.author}</p>
                  <p class="text-muted text-xs">{review.company}</p>
                </div>
              </div>
              <!-- Ícono plataforma -->
              <span style={`color: ${cfg.color}`} title={cfg.label}>
                <Fragment set:html={cfg.icon} />
              </span>
            </div>

            <!-- Estrellas -->
            <div class="flex gap-0.5">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Texto -->
            <p class="text-muted text-sm leading-relaxed flex-1">"{review.text}"</p>

            <!-- Footer: ubicación + fecha -->
            <div class="flex items-center justify-between pt-3 border-t border-border">
              <span class="text-xs text-muted-dark">{review.location}</span>
              <span class="text-xs text-muted">{review.date}</span>
            </div>
          </article>
        );
      })}
    </div>

    <!-- CTA ver más reseñas -->
    <div class="mt-10 text-center" data-anim="fade-up" data-delay="500">
      <p class="text-muted text-sm mb-4">¿Trabajaste con nosotros? Déjanos tu reseña.</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://g.page/r/review"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-border text-muted text-xs font-semibold px-4 py-2 rounded-md hover:border-blue hover:text-blue transition-colors"
        >
          <span style="color:#4285F4"><Fragment set:html={platformConfig.google.icon} /></span>
          Reseña en Google
        </a>
        <a
          href="https://facebook.com/av2rlamundial"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-border text-muted text-xs font-semibold px-4 py-2 rounded-md hover:border-blue hover:text-blue transition-colors"
        >
          <span style="color:#1877F2"><Fragment set:html={platformConfig.facebook.icon} /></span>
          Reseña en Facebook
        </a>
      </div>
    </div>

  </div>
</section>
