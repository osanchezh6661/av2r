<style is:global>
  .route-map-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }
  .route-group { animation: rFade 14s ease-in-out infinite; }
  @keyframes rFade {
    0%,   6%  { opacity: 0; }
    12%,  76% { opacity: 1; }
    88%, 100% { opacity: 0; }
  }
  .route-line { animation: rDraw 14s ease-in-out infinite; }
  @keyframes rDraw {
    0%,   8%   { stroke-dashoffset: 700; opacity: 0; }
    14%,  76%  { stroke-dashoffset: 0;   opacity: 1; }
    88%,  100% { stroke-dashoffset: 0;   opacity: 0; }
  }
</style>
