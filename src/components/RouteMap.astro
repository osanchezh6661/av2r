---
// RouteMap.astro — Animated route network (routes only, no state paths)
// Reduced from 176KB → ~4KB by removing the Mexico state polygon data
---

<div class="route-map-wrap" aria-hidden="true">
  <svg
    viewBox="90 20 880 610"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
    style="position:absolute;inset:0;width:100%;height:100%;display:block;"
  >
    <defs>
      <filter id="lineGlow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="2.5" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="nodeGlow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>

    <!-- ── Mexico simplified outline ── -->
    <!-- Mainland -->
    <path
      d="M 155,65
         L 180,62 L 220,60 L 265,62 L 310,70 L 355,80 L 400,95 L 445,112
         L 490,130 L 530,150 L 558,168 L 580,190 L 584,200
         L 620,205 L 658,208 L 690,215
         L 700,240 L 708,270 L 712,298 L 705,325 L 696,348 L 685,368
         L 675,388 L 668,408 L 665,435
         L 672,450 L 682,468 L 698,482 L 715,495 L 738,503 L 758,507
         L 778,503 L 790,498
         L 810,492 L 830,484 L 845,472 L 854,458 L 858,440 L 856,422 L 855,408
         L 855,392 L 852,375 L 860,358 L 870,345 L 882,332 L 895,322
         L 908,318 L 922,322 L 936,332 L 948,345 L 958,360 L 960,378
         L 958,398 L 950,418 L 940,432 L 928,446 L 915,458 L 902,466
         L 890,472 L 878,478 L 865,480 L 852,480
         L 840,480 L 825,490 L 808,500 L 790,510 L 772,522 L 755,535
         L 738,544 L 722,550 L 708,554 L 692,550
         L 672,548 L 650,552 L 628,550 L 605,545 L 582,535 L 558,520
         L 535,505 L 510,488 L 490,468 L 470,448 L 452,425 L 435,400
         L 418,375 L 400,348 L 382,320 L 362,292 L 340,265 L 318,240
         L 295,212 L 272,185 L 252,158 L 235,132 L 218,108 L 202,88
         L 185,72 L 168,65 Z"
      fill="rgba(92,159,224,0.07)"
      stroke="rgba(92,159,224,0.22)"
      stroke-width="1"
      stroke-linejoin="round"
    />
    <!-- Baja California peninsula -->
    <path
      d="M 155,65
         L 148,80 L 140,102 L 130,128 L 120,158 L 110,192
         L 103,228 L 97,262 L 94,298 L 94,332 L 96,358 L 102,382 L 110,402
         L 118,396 L 110,372 L 107,342 L 108,308 L 112,272 L 122,240
         L 136,208 L 150,178 L 160,148 L 165,118 L 165,90 L 162,72 Z"
      fill="rgba(92,159,224,0.07)"
      stroke="rgba(92,159,224,0.22)"
      stroke-width="1"
      stroke-linejoin="round"
    />

    <!-- ROUTE 1 — CDMX → Veracruz (delay: 0s) -->
    <g class="route-group" style="animation-delay:0s;">
      <path class="route-line" stroke-dasharray="100"
        d="M 597,458 L 622,452 L 638,444 L 655,438 L 665,435"
        fill="none" stroke="#5c9fe0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        filter="url(#lineGlow)"/>
      <g transform="translate(597,458)">
        <circle r="5" fill="#1a5fb8" filter="url(#nodeGlow)"/>
        <circle r="5" fill="none" stroke="#5c9fe0" stroke-width="1.5">
          <animate attributeName="r" values="5;17.5" dur="1.6s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.8;0" dur="1.6s" repeatCount="indefinite"/>
        </circle>
        <rect x="8" y="-18" width="38" height="14" fill="rgba(2,11,20,0.88)" rx="2"/>
        <text x="10" y="-7" font-size="9" fill="#8aabcc" font-family="Inter,sans-serif" font-weight="600" letter-spacing="0.5">CDMX</text>
      </g>
      <g transform="translate(665,435)">
        <circle r="5" fill="#1a5fb8" filter="url(#nodeGlow)"/>
        <circle r="5" fill="none" stroke="#5c9fe0" stroke-width="1.5">
          <animate attributeName="r" values="5;17.5" dur="1.6s" begin="1.4s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.8;0" dur="1.6s" begin="1.4s" repeatCount="indefinite"/>
