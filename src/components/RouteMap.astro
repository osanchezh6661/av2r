        <text x="10" y="-7" font-size="9" fill="#8aabcc" font-family="Inter,sans-serif" font-weight="600" letter-spacing="0.5">GUADALAJARA</text>
      </g>
      <g transform="translate(597,458)">
        <circle r="5" fill="#1a5fb8" filter="url(#nodeGlow)"/>
        <circle r="5" fill="none" stroke="#5c9fe0" stroke-width="1.5">
          <animate attributeName="r" values="5;17.5" dur="1.6s" begin="1.8s" repeatCount="indefinite"/>
