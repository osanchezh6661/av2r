---
const year = new Date().getFullYear();
const sectors = ['Industrial y manufactura', 'Comercial y distribución', 'Construcción', 'Agroindustrial'];
const navLinks = [
  { label: 'Servicios',    href: '#servicios' },
  { label: 'Rutas',        href: '#rutas' },
  { label: 'Empresa',      href: '#nosotros-info' },
  { label: 'Cómo funciona', href: '#como-funciona' },
  { label: 'Cotizar',      href: '#cotizar' },
];
---

<footer id="contacto" class="bg-navy">

  <!-- Google Maps strip -->
  <!-- TODO: Replace embed src with your specific address share link from Google Maps:
       1. Go to maps.google.com → search your address → Share → Embed a map → copy src URL -->
  <div class="grid lg:grid-cols-3" style="min-height:280px;">
    <!-- Map (2/3 width) -->
    <div class="lg:col-span-2 relative" style="min-height:280px;">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d120639.90447068795!2d-99.21228635!3d19.43260775!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce0026db097507%3A0x54061076265ee841!2sCiudad%20de%20M%C3%A9xico%2C%20CDMX!5e0!3m2!1ses-419!2smx!4v1713000000000!5m2!1ses-419!2smx"
        width="100%"
        height="100%"
        style="border:0;display:block;min-height:280px;filter:grayscale(1) invert(1) brightness(0.85);"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación AV2R La Mundial — Ciudad de México"
      ></iframe>
      <!-- Overlay with brand tint -->
      <div style="position:absolute;inset:0;background:rgba(11,29,58,0.18);pointer-events:none;" aria-hidden="true"></div>
    </div>

    <!-- Contact summary (1/3 width) -->
    <div class="bg-navy-mid flex flex-col justify-center px-8 py-10 gap-5"
         style="background:#0e2448;">
      <div>
        <p class="text-blue-accent text-[10px] font-bold uppercase tracking-widest mb-1">Base operativa</p>
        <p class="text-white font-bold text-base">Ciudad de México</p>
        <p class="text-muted-dark text-sm mt-0.5">Zona Metropolitana del Valle de México</p>
      </div>
      <div class="space-y-3">
        <a href="tel:5510530425"
           class="flex items-center gap-3 text-muted-dark hover:text-white transition-colors group">
          <svg class="w-4 h-4 text-blue-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          <span class="text-sm">55 1053 0425</span>
        </a>
        <a href="mailto:contacto@av2rlamundial.com"
           class="flex items-center gap-3 text-muted-dark hover:text-white transition-colors">
          <svg class="w-4 h-4 text-blue-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          <span class="text-sm">contacto@av2rlamundial.com</span>
        </a>
        <a href="https://wa.me/525510530425" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-3 text-muted-dark hover:text-[#25D366] transition-colors">
          <svg class="w-4 h-4 text-blue-accent shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <span class="text-sm">WhatsApp directo</span>
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-14">
    <div class="grid md:grid-cols-3 gap-10 lg:gap-16">

      <!-- Col 1: Logo + tagline -->
      <div class="space-y-4" data-anim="fade-up" data-delay="0">
        <img
          src="/logo.svg"
          alt="AV2R La Mundial"
          class="h-10 w-auto"
          style="filter:brightness(0) invert(1);"
          width="160"
          height="40"
          loading="lazy"
        />
        <p class="text-muted-dark text-sm leading-relaxed max-w-xs">
          Transporte terrestre de carga con cobertura nacional.
          Puntualidad, seguridad y seguimiento constante en cada servicio.
        </p>
        <!-- Socials placeholder -->
        <div class="flex gap-3 pt-1">
          <a href="https://www.facebook.com/people/AV2R-La-Mundial/61586245051615/" target="_blank" rel="noopener noreferrer" aria-label="Facebook AV2R"
             class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-muted-dark hover:text-white hover:border-white/30 transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://wa.me/525510530425" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp AV2R"
             class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-muted-dark hover:text-[#25D366] hover:border-[#25D366]/40 transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Nav + Sectors -->
      <div class="grid grid-cols-2 gap-8" data-anim="fade-up" data-delay="100">
        <div>
          <h3 class="text-white text-xs font-bold uppercase tracking-widest mb-4">Navegación</h3>
          <ul class="space-y-2.5">
            {navLinks.map((l) => (
              <li>
                <a href={l.href} class="text-muted-dark text-sm hover:text-white transition-colors">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-white text-xs font-bold uppercase tracking-widest mb-4">Sectores</h3>
          <ul class="space-y-2.5">
            {sectors.map((s) => (
              <li>
                <a href="#servicios" class="text-muted-dark text-sm hover:text-white transition-colors">
                  {s}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Col 3: Contact -->
      <div data-anim="fade-up" data-delay="200">
        <h3 class="text-white text-xs font-bold uppercase tracking-widest mb-4">Contacto</h3>
        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-blue-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            <a href="tel:5510530425" class="text-sm text-muted-dark hover:text-white transition-colors">
              55 1053 0425
            </a>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-blue-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <span class="text-sm text-muted-dark">Ciudad de México y Zona Metropolitana</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-blue-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <span class="text-sm text-muted-dark">contacto@av2rlamundial.com</span>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-muted-dark text-xs">
        &copy; {year} AV2R La Mundial. Todos los derechos reservados.
      </p>
      <p class="text-muted-dark text-xs">
        Transporte terrestre · Ciudad de México · NOM-068 · NOM-012
      </p>
    </div>
  </div>

</footer>
