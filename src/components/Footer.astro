---
const year = new Date().getFullYear();
const services = ['Carga General', 'Jaula Ganadera', 'Plataforma', 'Carga Local CDMX'];
---
<footer id="contacto" class="bg-navy">

  <!-- Cuerpo del footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-14">
    <div class="grid md:grid-cols-3 gap-10">

      <!-- Col 1: Logo + descripción -->
      <div class="space-y-4" data-anim="fade-up" data-delay="0">
        <img
          src="/logo.svg"
          alt="AV2R La Mundial"
          class="h-12 w-auto"
          style="filter: brightness(0) invert(1);"
          width="192"
          height="48"
          loading="lazy"
        />
        <p class="text-muted-dark text-sm leading-relaxed max-w-xs">
          Empresa de transporte terrestre de carga con cobertura nacional.
          Comprometidos con la puntualidad y la seguridad de tu mercancía.
        </p>
      </div>

      <!-- Col 2: Servicios -->
      <div data-anim="fade-up" data-delay="100">
        <h3 class="text-white text-sm font-semibold mb-5">Servicios</h3>
        <ul class="space-y-2.5">
          {services.map((s) => (
            <li>
              <a href="#servicios" class="text-muted-dark text-sm hover:text-white transition-colors">
                {s}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contacto -->
      <div data-anim="fade-up" data-delay="200">
        <h3 class="text-white text-sm font-semibold mb-5">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-blue-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a href="tel:5510530425" class="text-sm text-muted-dark hover:text-white transition-colors">
              55 1053 0425
            </a>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-blue-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm text-muted-dark">Ciudad de México, México</span>
          </li>
        </ul>
        <div class="mt-6">
          <a
            href="#cotizar"
            class="inline-flex items-center gap-2 bg-blue text-white text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-[#1550a0] transition-colors"
          >
            Solicitar cotización
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Barra inferior -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-muted-dark text-xs">
        &copy; {year} AV2R La Mundial. Todos los derechos reservados.
      </p>
      <p class="text-muted-dark text-xs">
        Transporte terrestre · Ciudad de México
      </p>
    </div>
  </div>

</footer>
