---
// TODO: Actualizar con datos reales del cliente
// Para activar el contador: reemplaza value por un número real
// y agrega data-target={stat.value} data-suffix={stat.suffix} al <dd>
const stats = [
  { value: '15',  suffix: '+',  label: 'Años de experiencia',  decimal: false },
  { value: '200', suffix: '+',  label: 'Unidades activas',      decimal: false },
  { value: '98',  suffix: '%',  label: 'Entregas a tiempo',     decimal: false },
  { value: '32',  suffix: '',   label: 'Estados con cobertura', decimal: false },
];
---
<div id="nosotros" class="bg-navy overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-10">
    <dl class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
      {stats.map((stat, i) => (
        <div
          class="px-6 first:pl-0 last:pr-0 text-center py-4 lg:py-0"
          data-anim="fade-up"
          data-delay={i * 120}
        >
          <dd
            class="stat-num neon-num text-4xl font-bold text-white tracking-tight"
            data-counter
            data-target={stat.value}
            data-suffix={stat.suffix}
            data-decimal={stat.decimal}
          >
            0{stat.suffix}
          </dd>
          <dt class="text-xs text-muted-dark mt-1.5">{stat.label}</dt>
        </div>
      ))}
    </dl>
  </div>
</div>
