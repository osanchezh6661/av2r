---
// TODO: Validar con el cliente los datos de cada diferenciador
const differentiators = [
  {
    title: 'Flota propia, sin intermediarios',
    desc: 'No subcontratamos. Todas nuestras unidades son propias, lo que nos permite garantizar disponibilidad, calidad y tiempos de respuesta que ningún bróker puede ofrecer.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
    </svg>`,
    highlight: 'Flota 100% propia',
  },
  {
    title: 'Cotización en menos de 2 horas',
    desc: 'Sabemos que en logística el tiempo es dinero. Te damos precio final antes de que cualquier otro competidor te conteste el teléfono. Sin formularios largos.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`,
    highlight: 'Respuesta < 2 hrs',
  },
  {
    title: 'Especialistas en carga ganadera',
    desc: 'Somos de los pocos transportistas con jaulas certificadas para ganado bovino, porcino y ovino. Conocemos las normativas de bienestar animal y las rutas zoosanitarias del sureste.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
    </svg>`,
    highlight: 'Jaulas certificadas',
  },
  {
    title: 'Corredor Interoceánico: experiencia de primera mano',
    desc: 'Operamos en el Istmo de Tehuantepec desde antes de que se convirtiera en el corredor más importante del comercio exterior mexicano. Conocemos cada tramo, cada punto de control.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
    </svg>`,
    highlight: 'Ruta interoceánica',
  },
];
---
<section
  class="py-16 lg:py-20"
  style="background: linear-gradient(180deg, #f5f6fa 0%, #ffffff 100%);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="mb-12">
      <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3"
         data-anim="fade-up">
        Nuestras ventajas
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight max-w-xl"
          data-anim="fade-up" data-delay="80">
        Por qué elegir AV2R La Mundial
      </h2>
    </div>

    <!-- Grid 2×2 -->
    <div class="grid sm:grid-cols-2 gap-6">
      {differentiators.map((d, i) => (
        <article
          class="neon-card group relative bg-white border border-border rounded-xl p-6 overflow-hidden"
          data-anim="fade-up"
          data-delay={i * 100}
        >
          <!-- Fondo decorativo navy en hover -->
          <div class="absolute inset-0 bg-navy opacity-0 group-hover:opacity-[0.02] transition-opacity rounded-xl" aria-hidden="true"></div>

          <div class="flex items-start gap-4">
            <!-- Ícono -->
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 text-blue"
              style="background: rgba(26,95,184,0.08);"
            >
              <Fragment set:html={d.icon} />
            </div>

            <div class="flex-1">
              <!-- Badge highlight -->
              <span class="inline-block text-[10px] font-bold text-blue bg-blue/8 px-2 py-0.5 rounded-full tracking-wide mb-2">
                {d.highlight}
              </span>
              <h3 class="text-navy font-semibold text-sm mb-2">{d.title}</h3>
              <p class="text-muted text-xs leading-relaxed">{d.desc}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
