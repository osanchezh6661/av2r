---

<section id="flota" class="bg-navy bg-hex-lines py-16 lg:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="mb-12">
      <p class="text-blue-accent text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
        Tipos de unidades
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight" data-anim="fade-up" data-delay="80">
        La unidad correcta para cada carga
      </h2>
      <p class="text-muted-dark text-sm mt-3 max-w-lg" data-anim="fade-up" data-delay="140">
        Contamos con diferentes equipos para adaptarnos al tipo de mercancía y las condiciones de cada servicio.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {units.map((u, i) => (
        <article
          class="fleet-card flex flex-col gap-4 rounded-xl p-6 border transition-all duration-300"
          style={u.highlight
            ? 'background:rgba(26,95,184,0.15);border-color:rgba(92,159,224,0.40);'
            : 'background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.08);'}
          data-anim="fade-up"
          data-delay={i * 80}
        >
          <!-- Icon + badge row -->
          <div class="flex items-start justify-between gap-3">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0"
                 style={u.highlight
                   ? 'background:rgba(26,95,184,0.35);color:#5c9fe0;'
                   : 'background:rgba(255,255,255,0.07);color:#5c9fe0;'}>
              <Fragment set:html={u.icon} />
            </div>
            <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shrink-0"
                  style={u.highlight
                    ? 'background:rgba(26,95,184,0.30);color:#5c9fe0;'
                    : 'background:rgba(255,255,255,0.06);color:#607a96;'}>
              {u.badge}
            </span>
          </div>

          <!-- Name + description -->
          <div>
            <h3 class="text-white font-bold text-base mb-1.5">{u.name}</h3>
            <p class="text-muted-dark text-xs leading-relaxed">{u.desc}</p>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5 mt-auto">
            {u.tags.map(tag => (
              <span class="text-[10px] font-medium px-2 py-0.5 rounded-md"
                    style="background:rgba(255,255,255,0.06);color:#607a96;">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom note -->
    <p class="text-center text-xs text-muted-dark mt-8 opacity-60" data-anim="fade-up" data-delay="500">
      Disponibilidad de unidades sujeta a consulta · <a href="#cotizar" class="hover:text-white transition-colors underline underline-offset-2">Solicita tu cotización</a>
    </p>

  </div>
</section>

<style is:global>
  .fleet-card:hover {
    border-color: rgba(92, 159, 224, 0.30) !important;
    background: rgba(255,255,255,0.07) !important;
  }
</style>
