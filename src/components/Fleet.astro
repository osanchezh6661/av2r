---
import { Image } from 'astro:assets';
import cajaSecaImg       from '../assets/img/caja-seca.png';
import cajaLocalImg      from '../assets/img/caja-local.png';
import jaulaImg          from '../assets/img/jaula.png';
import planaImg          from '../assets/img/plana.png';
import tortonImg         from '../assets/img/torton.png';
import portaContenedorImg from '../assets/img/porta-contenedor.png';

type Unit = {
  name: string; badge: string; desc: string; tags: string[];
  alt: string; highlight: boolean; src: ImageMetadata;
};

const units: Unit[] = [
  {
    name: 'Caja Seca',
    badge: 'Unidad principal',
    desc: 'Caja de acero cerrada que protege la carga de la intemperie en trayectos cortos y nacionales.',
    tags: ['Manufactura', 'Distribución comercial', 'Producto empacado'],
    src: cajaSecaImg,
    alt: 'Camión caja seca para transporte de carga pesada en México — AV2R La Mundial',
    highlight: true,
  },
  {
    name: 'Torton',
    badge: 'Carga pesada',
    desc: 'Mayor tonelaje para cargas voluminosas en rutas nacionales de largo recorrido.',
    tags: ['Materias primas', 'Industrial pesado', 'Granel y bulto'],
    src: tortonImg,
    alt: 'Torton para transporte de carga industrial y granel en México — AV2R La Mundial',
    highlight: false,
  },
  {
    name: 'Carga Local',
    badge: 'Última milla',
    desc: 'Unidades ágiles para distribución urbana dentro de CDMX y la Zona Metropolitana.',
    tags: ['Reparto en ciudad', 'CDMX y ZMVM', 'Entrega rápida'],
    src: cajaLocalImg,
    alt: 'Unidad de carga local para distribución urbana en CDMX y Zona Metropolitana — AV2R La Mundial',
    highlight: false,
  },
  {
    name: 'Jaula',
    badge: 'Carga ventilada',
    desc: 'Estructura de rejilla con circulación de aire. Ideal para producto de campo y carga voluminosa.',
    tags: ['Agroindustrial', 'Hortalizas y frutas', 'Insumos de campo'],
    src: jaulaImg,
    alt: 'Camión jaula para transporte agroindustrial y carga ventilada en México — AV2R La Mundial',
    highlight: false,
  },
  {
    name: 'Plana',
    badge: 'Sobredimensionada',
    desc: 'Plataforma abierta para maquinaria, estructuras metálicas y material que no cabe en caja cerrada.',
    tags: ['Maquinaria pesada', 'Estructuras metálicas', 'Construcción'],
    src: planaImg,
    alt: 'Plataforma plana para transporte de maquinaria pesada y estructuras metálicas — AV2R La Mundial',
    highlight: false,
  },
  {
    name: 'Porta Contenedor',
    badge: 'Comercio exterior',
    desc: 'Equipo especializado para traslado de contenedores 20\' y 40\'. Importación y exportación.',
    tags: ["Contenedores 20' y 40'", 'Importación / exportación', 'Puertos'],
    src: portaContenedorImg,
    alt: 'Porta contenedor para importación y exportación en México — AV2R La Mundial',
    highlight: false,
  },
];
---

<section id="flota" class="bg-navy bg-hex-lines py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="mb-12">
      <p class="text-blue-accent text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
        Tipos de unidades
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight" data-anim="fade-up" data-delay="80">
        La unidad correcta para cada carga
      </h2>
      <p class="text-muted-dark text-sm mt-3 max-w-lg" data-anim="fade-up" data-delay="140">
        Contamos con diferentes equipos para adaptarnos al tipo de mercancía y las condiciones de cada servicio.
      </p>
    </div>

    <!-- 3×2 photo card grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {units.map((u, i) => (
        <article
          class="fleet-photo-card relative rounded-xl overflow-hidden group cursor-default"
          style="height:260px;"
          data-anim="fade-up"
          data-delay={i * 80}
        >
          <!-- Full-bleed photo -->
          <Image
            src={u.src}
            alt={u.alt}
            widths={[400, 800]}
            sizes="(min-width:1024px) 33vw, (min-width:640px) 50vw, 100vw"
            format="webp"
            quality={82}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />

          <!-- Dark gradient overlay — heavier at bottom -->
          <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(2,11,20,0.94) 0%, rgba(2,11,20,0.65) 38%, rgba(2,11,20,0.20) 65%, transparent 100%);" aria-hidden="true"></div>

          <!-- Highlight border for primary unit -->
          {u.highlight && (
            <div class="absolute inset-0 rounded-xl pointer-events-none" style="box-shadow:inset 0 0 0 2px rgba(92,159,224,0.50);" aria-hidden="true"></div>
          )}

          <!-- Badge — top right -->
          <div class="absolute top-4 right-4">
            <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full"
                  style={u.highlight
                    ? 'background:rgba(26,95,184,0.80);color:#a8c8f0;border:1px solid rgba(92,159,224,0.40);backdrop-filter:blur(6px);'
                    : 'background:rgba(2,11,20,0.70);color:#607a96;border:1px solid rgba(255,255,255,0.12);backdrop-filter:blur(6px);'}>
              {u.badge}
            </span>
          </div>

          <!-- Content — bottom -->
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-white font-bold text-lg leading-tight mb-2"
                style={u.highlight ? 'text-shadow:0 1px 8px rgba(0,0,0,0.6);' : ''}>
              {u.name}
            </h3>

            <!-- Tags (always visible) -->
            <div class="flex flex-wrap gap-1.5">
              {u.tags.map(tag => (
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-md"
                      style="background:rgba(92,159,224,0.18);color:#8aabcc;backdrop-filter:blur(4px);">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Description — slides up on hover -->
            <p class="text-white/0 group-hover:text-white/75 text-xs leading-relaxed transition-all duration-300 overflow-hidden"
               style="max-height:0;transition:max-height 0.3s ease, color 0.3s ease;"
               data-desc={u.desc}>
            </p>
          </div>
        </article>
      ))}
    </div>

    <p class="text-center text-xs text-muted-dark mt-8 opacity-60" data-anim="fade-up" data-delay="520">
      Disponibilidad de unidades sujeta a consulta
    </p>

  </div>
</section>

<script is:inline>
  /* Animate description slide-up on hover */
  document.querySelectorAll('.fleet-photo-card').forEach(card => {
    const desc = card.querySelector('[data-desc]');
    if (!desc) return;
    desc.textContent = desc.dataset.desc;
    card.addEventListener('mouseenter', () => {
      desc.style.maxHeight = '60px';
      desc.style.color = 'rgba(255,255,255,0.75)';
    });
    card.addEventListener('mouseleave', () => {
      desc.style.maxHeight = '0';
      desc.style.color = 'rgba(255,255,255,0)';
    });
  });
</script>

<style is:global>
  .fleet-photo-card img { will-change: transform; }
</style>
