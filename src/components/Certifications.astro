---
// TODO: Validar números de permiso y certificaciones reales con el cliente
const certs = [
  {
    label: 'Permiso SCT Federal',
    sub: 'Autotransporte federal de carga',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
    </svg>`,
  },
  {
    label: 'NOM-012 Cumplimiento',
    sub: 'Pesos y dimensiones vehiculares',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
    </svg>`,
  },
  {
    label: 'Seguro de carga activo',
    sub: 'Cobertura en todos los servicios',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.764c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.752h-.152c-3.196 0-6.1-1.248-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />
    </svg>`,
  },
  {
    label: 'Rastreo GPS 24/7',
    sub: 'Visibilidad total de tu embarque',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
    </svg>`,
  },
  {
    label: 'REPSE Registrado',
    sub: 'Registro de prestadores de servicios',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
    </svg>`,
  },
  {
    label: 'Operadores certificados',
    sub: 'Licencia federal y capacitación continua',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
    </svg>`,
  },
];
---
<div class="bg-white border-b border-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6">
    <p class="text-muted text-[10px] font-semibold tracking-widest uppercase text-center mb-5"
       data-anim="fade-up">
      Cumplimiento y certificaciones
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {certs.map((cert, i) => (
        <div
          class="flex flex-col items-center text-center gap-2 group"
          data-anim="fade-up"
          data-delay={i * 70}
        >
          <div class="w-10 h-10 rounded-full bg-blue/8 flex items-center justify-center text-blue group-hover:bg-blue/15 transition-colors">
            <Fragment set:html={cert.icon} />
          </div>
          <div>
            <p class="text-navy text-[11px] font-semibold leading-tight">{cert.label}</p>
            <p class="text-muted text-[10px] leading-tight mt-0.5">{cert.sub}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
