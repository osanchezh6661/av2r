  { label: 'Monitoreo GPS 24/7', icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>` },
  { label: 'Seguro de carga incluido', icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>` },
  { label: 'Operadores con licencia federal', icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>` },
];
---

<section id="servicios" class="bg-surface bg-dots py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="mb-12">
      <p class="text-blue text-xs font-semibold tracking-widest uppercase mb-3" data-anim="fade-up">
        Sectores que atendemos
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-navy tracking-tight" data-anim="fade-up" data-delay="80">
        Soluciones para cada tipo de industria
      </h2>
      <p class="text-muted text-sm mt-3 max-w-lg" data-anim="fade-up" data-delay="140">
        Nos integramos como socio logístico, adaptándonos a las necesidades operativas de cada cliente.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 mb-10">
      {sectors.map((s, i) => (
        <article
          class="neon-card bg-white border border-border rounded-xl p-6 flex items-start gap-5 cursor-default"
          data-anim="fade-up"
          data-delay={i * 90}
        >
          <span class="text-xs font-bold text-blue min-w-[2rem] pt-0.5 shrink-0">{s.num}</span>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-lg flex items-center justify-center text-blue shrink-0"
                 style="background:rgba(26,95,184,0.08);">
              <Fragment set:html={s.icon} />
            </div>
            <div>
              <h3 class="text-sm font-semibold text-navy mb-1.5">{s.title}</h3>
              <p class="text-xs text-muted leading-relaxed">{s.desc}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Capabilities strip -->
    <div class="rounded-xl border border-border bg-white px-6 py-5 flex flex-wrap items-center gap-x-8 gap-y-3"
         data-anim="fade-up" data-delay="380">
      <span class="text-[10px] font-bold text-muted uppercase tracking-widest shrink-0">Características del servicio</span>
      <div class="w-px h-4 bg-border hidden sm:block shrink-0" aria-hidden="true"></div>
      {capabilities.map((c) => (
        <div class="flex items-center gap-2">
          <span class="text-blue"><Fragment set:html={c.icon} /></span>
          <span class="text-xs text-navy font-medium">{c.label}</span>
        </div>
      ))}
    </div>


  </div>
</section>
