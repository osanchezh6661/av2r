---
const zones = [
  {
    name: 'CDMX y ZM',
    states: 'Ciudad de México · Estado de México · Hidalgo',
    color: '#1a5fb8',
    label: 'Base operativa',
  },
  {
    name: 'Corredor Veracruz',
    states: 'Veracruz · Tlaxcala · Puebla',
    color: '#00c8ff',
    label: 'Ruta principal',
  },
  {
    name: 'Sureste',
    states: 'Oaxaca · Chiapas · Tabasco · Campeche · Yucatán · Q. Roo',
    color: '#5c9fe0',
    label: 'Cobertura total',
  },
  {
    name: 'Corredor Interoceánico',
    states: 'Istmo de Tehuantepec (Coatzacoalcos ↔ Salina Cruz)',
    color: '#00e5a0',
    label: 'Ruta estratégica',
  },
];
---
<section class="bg-navy py-16 lg:py-20 overflow-hidden" id="cobertura">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-blue-accent text-xs font-semibold tracking-widest uppercase mb-3"
         data-anim="fade-up">
        Cobertura geográfica
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight"
          data-anim="fade-up" data-delay="80">
        Llegamos a cada rincón del sureste
      </h2>
      <p class="text-[#7a9bbf] text-sm mt-3 max-w-lg mx-auto"
         data-anim="fade-up" data-delay="160">
        Operamos rutas establecidas hacia los principales mercados del sureste mexicano
        y el Corredor Interoceánico.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Mapa SVG estilizado de México -->
      <div data-anim="scale-up" data-delay="100">
        <div class="relative">
          <!-- Contenedor del mapa con glow -->
          <div
            class="rounded-2xl overflow-hidden"
            style="border: 1px solid rgba(0,200,255,0.2); box-shadow: 0 0 60px rgba(0,200,255,0.06);"
          >
            <svg
              viewBox="0 0 520 380"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              class="w-full h-auto"
              style="background: rgba(11,29,58,0.8);"
              aria-label="Mapa de cobertura AV2R en México"
            >
              <!-- Fondo sutil -->
              <defs>
                <radialGradient id="mapGlow" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="rgba(26,95,184,0.15)"/>
                  <stop offset="100%" stop-color="transparent"/>
                </radialGradient>
                <filter id="glow">
                  <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
                  <feMerge>
                    <feMergeNode in="coloredBlur"/>
                    <feMergeNode in="SourceGraphic"/>
                  </feMerge>
                </filter>
              </defs>

              <rect width="520" height="380" fill="url(#mapGlow)"/>

              <!-- Silueta simplificada de México (contorno aproximado) -->
              <!-- Noroeste / Baja California -->
              <path d="M 60 30 L 80 20 L 95 40 L 85 90 L 70 130 L 55 150 L 45 140 L 50 100 L 60 60 Z"
                    fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
              <!-- Noroeste continental -->
              <path d="M 95 40 L 140 30 L 170 45 L 165 80 L 150 95 L 130 90 L 110 85 L 95 70 Z"
                    fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
              <!-- Norte -->
              <path d="M 140 30 L 270 25 L 300 50 L 280 90 L 250 110 L 200 105 L 170 95 L 165 80 L 170 45 Z"
                    fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
              <!-- Noreste -->
              <path d="M 270 25 L 330 20 L 360 50 L 350 100 L 320 120 L 300 110 L 300 50 Z"
                    fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
              <!-- Centro-Occidente -->
              <path d="M 165 95 L 200 105 L 220 130 L 210 160 L 190 170 L 165 160 L 155 140 L 160 115 Z"
                    fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>

              <!-- ZONA 1: CDMX y ZM — resaltada en azul -->
              <ellipse cx="215" cy="165" rx="22" ry="16"
                       fill="rgba(26,95,184,0.5)" stroke="#1a5fb8" stroke-width="1.5"
                       filter="url(#glow)"/>
              <circle cx="215" cy="165" r="5" fill="#1a5fb8"
                      style="filter: drop-shadow(0 0 6px #1a5fb8);"/>

              <!-- ZONA 2: Veracruz corridor — línea y punto -->
              <path d="M 215 165 Q 270 155 305 175"
                    stroke="#00c8ff" stroke-width="2.5" stroke-dasharray="6,3"
                    style="filter: drop-shadow(0 0 4px rgba(0,200,255,0.8));"/>
              <circle cx="305" cy="175" r="6" fill="#00c8ff" opacity="0.9"
                      style="filter: drop-shadow(0 0 8px rgba(0,200,255,0.9));"/>
              <!-- Zona Veracruz -->
              <ellipse cx="310" cy="178" rx="28" ry="20"
                       fill="rgba(0,200,255,0.15)" stroke="#00c8ff" stroke-width="1" opacity="0.7"/>

              <!-- ZONA 3: Sureste — puntos y región -->
              <path d="M 215 165 Q 240 210 270 230 Q 310 255 345 240 Q 370 228 375 210"
                    stroke="#5c9fe0" stroke-width="2" stroke-dasharray="5,3" opacity="0.8"/>
              <!-- Puntos del sureste -->
              <circle cx="270" cy="240" r="5" fill="#5c9fe0" opacity="0.9"
                      style="filter: drop-shadow(0 0 6px #5c9fe0);"/>
              <circle cx="310" cy="255" r="5" fill="#5c9fe0" opacity="0.9"/>
              <circle cx="345" cy="242" r="5" fill="#5c9fe0" opacity="0.9"/>
              <circle cx="375" cy="225" r="5" fill="#5c9fe0" opacity="0.9"/>
              <circle cx="395" cy="210" r="4" fill="#5c9fe0" opacity="0.7"/>
              <!-- Yucatán -->
              <circle cx="380" cy="190" r="5" fill="#5c9fe0" opacity="0.9"/>

              <!-- ZONA 4: Corredor Interoceánico — línea especial -->
              <path d="M 305 195 L 290 225 L 295 245"
                    stroke="#00e5a0" stroke-width="3"
                    style="filter: drop-shadow(0 0 6px rgba(0,229,160,0.8));"/>
              <circle cx="295" cy="245" r="5" fill="#00e5a0"
                      style="filter: drop-shadow(0 0 8px rgba(0,229,160,0.9));"/>
              <circle cx="305" cy="195" r="5" fill="#00e5a0"
                      style="filter: drop-shadow(0 0 8px rgba(0,229,160,0.9));"/>

              <!-- Etiquetas -->
              <text x="185" y="162" fill="white" font-size="8" font-weight="bold" font-family="sans-serif">CDMX</text>
              <text x="310" y="168" fill="#00c8ff" font-size="7" font-family="sans-serif">Veracruz</text>
              <text x="260" y="270" fill="#5c9fe0" font-size="7" font-family="sans-serif">Sureste</text>
              <text x="258" y="215" fill="#00e5a0" font-size="6.5" font-family="sans-serif" transform="rotate(-55,260,215)">Interoceánico</text>

              <!-- Leyenda interna -->
              <text x="30" y="340" fill="rgba(255,255,255,0.4)" font-size="8" font-family="sans-serif">
                Mapa ilustrativo — cobertura aproximada
              </text>
            </svg>
          </div>
        </div>
      </div>

      <!-- Zonas de cobertura lista -->
      <div class="space-y-4" data-anim="fade-up" data-delay="200">
        {zones.map((zone, i) => (
          <div
            class="flex items-start gap-4 p-4 rounded-xl"
            style={`border: 1px solid ${zone.color}30; background: ${zone.color}08;`}
            data-anim="slide-right"
            data-delay={i * 100}
          >
            <!-- Dot con glow -->
            <div
              class="w-3 h-3 rounded-full shrink-0 mt-1.5"
              style={`background: ${zone.color}; box-shadow: 0 0 10px ${zone.color};`}
            ></div>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <h3 class="text-white text-sm font-semibold">{zone.name}</h3>
                <span
                  class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                  style={`color: ${zone.color}; background: ${zone.color}18;`}
                >
                  {zone.label}
                </span>
              </div>
              <p class="text-[#7a9bbf] text-xs">{zone.states}</p>
            </div>
          </div>
        ))}

        <!-- Nota cobertura amplia -->
        <div class="mt-6 p-4 rounded-xl border border-white/10 bg-white/5">
          <p class="text-[#7a9bbf] text-xs leading-relaxed">
            <span class="text-white font-medium">¿Tu destino no aparece?</span>{' '}
            Cubrimos toda la República Mexicana. Contáctanos para verificar disponibilidad
            en tu ruta específica.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
