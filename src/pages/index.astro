---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Certifications from '../components/Certifications.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Stats from '../components/Stats.astro';
import FleetBanner from '../components/FleetBanner.astro';
import Industries from '../components/Industries.astro';
import Services from '../components/Services.astro';
import WhyAV2R from '../components/WhyAV2R.astro';
import Testimonials from '../components/Testimonials.astro';
import Routes from '../components/Routes.astro';
import CoverageMap from '../components/CoverageMap.astro';
import About from '../components/About.astro';
import FAQ from '../components/FAQ.astro';
import QuoteSection from '../components/QuoteSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <main>
    <Hero />
    <TrustBar />
    <Certifications />
    <HowItWorks />
    <Stats />
    <FleetBanner />
    <Industries />
    <Services id="servicios" />
    <WhyAV2R />
    <Testimonials />
    <Routes />
    <CoverageMap />
    <About />
    <FAQ />
    <QuoteSection />
  </main>
  <Footer />
</Layout>
